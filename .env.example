# ──────────────────────────────────────────────────────────────────────────────
# MERNShop — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored — NEVER commit real secrets.
# ──────────────────────────────────────────────────────────────────────────────

# ── Public (exposed to browser — MUST start with NEXT_PUBLIC_) ────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=MERNShop

# ── MERN-III: Express + MongoDB backend URL ────────────────────────────────────
# Set this on Vercel to point the frontend at your Railway/Render backend.
# Leave empty in MERN-II — the app uses local mock JSON.
# NEXT_PUBLIC_API_URL=https://your-backend.railway.app

# ── Server-only (never sent to browser) ───────────────────────────────────────
NODE_ENV=development

# ── MERN-III: MongoDB connection string ───────────────────────────────────────
# DATABASE_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/mernshop

# ── MERN-IV: NextAuth.js ──────────────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
# NEXTAUTH_SECRET=your-minimum-32-character-secret-here
# NEXTAUTH_URL=https://your-vercel-app.vercel.app

# ── Build flags ───────────────────────────────────────────────────────────────
# Set to true in Vercel to skip t3-env validation during build
# (useful when DATABASE_URL / NEXTAUTH_SECRET are not yet configured)
# SKIP_ENV_VALIDATION=true
