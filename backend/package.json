{
  "name": "mernshop-backend",
  "version": "1.0.0",
  "description": "MERNShop — Complete Production Backend (All 9 Modules)",
  "type": "module",
  "scripts": {
    "seed": "tsx src/cli/seed.ts",
    "seed:electronics": "tsx src/cli/seed.ts --filter Electronics",
    "seed:fashion": "tsx src/cli/seed.ts --filter Fashion",
    "seed:home": "tsx src/cli/seed.ts --filter \"Home & Kitchen\"",
    "seed:books": "tsx src/cli/seed.ts --filter Books",
    "seed:sports": "tsx src/cli/seed.ts --filter Sports",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:seed": "tsx src/cli/dbSeed.ts",
    "test": "jest --forceExit",
    "test:coverage": "jest --coverage --forceExit",
    "db:admin": "tsx src/cli/seedAdmin.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "mongoose": "^8.4.1",
    "morgan": "^1.10.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "cookie-parser": "^1.4.6",
    "express-rate-limit": "^7.3.1",
    "express-mongo-sanitize": "^2.2.0",
    "hpp": "^0.2.3",
    "compression": "^1.7.4",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.7.5",
    "nodemailer": "^6.9.14",
    "cloudinary": "^2.2.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.9",
    "@types/uuid": "^10.0.0",
    "mongodb-memory-server": "^10.0.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/compression": "^1.7.5",
    "@types/hpp": "^0.2.6",
    "@types/multer": "^1.4.11",
    "@types/nodemailer": "^6.4.15",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "supertest": "^7.0.0",
    "@types/jest": "^29.5.12",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6"
  }
}