{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "env": {
    "SKIP_ENV_VALIDATION": "true",
    "NEXT_PUBLIC_BASE_URL": "https://mern-shop-swart.vercel.app",
    "NEXT_PUBLIC_APP_NAME": "MERNShop"
  },
  "headers": [
    {
      "source": "/og-image.jpg",
      "headers": [
        {
          "key": "Content-Type",
          "value": "image/jpeg"
        }
      ]
    }
  ]
}